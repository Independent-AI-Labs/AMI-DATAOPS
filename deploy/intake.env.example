# Intake deployment secrets. Copy to `deploy/intake.env`, fill in, chmod 0600.
# `deploy/intake.env` is git-ignored — never commit real values.

# --- One-time Cloudflare bootstrap (NOT needed at runtime) ---
#
# Scope this token to: Cloudflare Tunnel: Edit AND DNS: Edit on zone ami-remote.work.
# After `ami-serve bootstrap-cloudflare` prints its JSON output and you've pasted
# the tunnel_id into deploy/intake.vars.yml, the token can be rotated/revoked.
CLOUDFLARE_API_TOKEN=cf_token_xxx
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ZONE_ID=your_zone_id_for_ami_remote_work

# --- Runtime intake auth (required, read by ami-intake.service via EnvironmentFile=) ---
#
# One pair per allowed sender declared in dataops_intake_config.allowed_senders.
# Generate each with:  openssl rand -hex 32
AMI_INTAKE_TOKENS__REPORTS=replace_with_openssl_rand_hex_32
AMI_INTAKE_SECRETS__REPORTS=replace_with_openssl_rand_hex_32
